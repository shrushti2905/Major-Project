{
  "name": "skillswap-platform",
  "version": "1.0.0",
  "scripts": {
    "backend": "cd backend && venv\\Scripts\\activate && python app.py",
    "frontend": "cd client && npm run dev",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "seed": "cd backend && venv\\Scripts\\activate && python seed.py",
    "install-all": "npm install && cd client && npm install && cd ../backend && python -m venv venv && venv\\Scripts\\activate && pip install -r requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
